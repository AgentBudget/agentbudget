{
  "name": "@agentbudget/agentbudget",
  "version": "0.3.1",
  "description": "Real-time cost enforcement for AI agent sessions — works with OpenAI and Anthropic",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern='index\\.test'",
    "test:smoke": "node --experimental-vm-modules node_modules/.bin/jest --testPathPattern='smoke\\.test'"
  },
  "jest": {
    "testEnvironment": "node",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "ESNext",
            "moduleResolution": "bundler"
          }
        }
      ]
    },
    "testMatch": [
      "**/src/**/*.test.ts"
    ]
  },
  "keywords": [
    "ai",
    "agents",
    "budget",
    "cost",
    "openai",
    "anthropic",
    "llm",
    "cost-tracking"
  ],
  "author": "AgentBudget",
  "license": "Apache-2.0",
  "homepage": "https://agentbudget.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentBudget/agentbudget.git",
    "directory": "sdks/typescript"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.19.37",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.20.0",
    "openai": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
